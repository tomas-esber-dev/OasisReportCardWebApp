rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Coaches ──────────────────────────────────────────────────────────────
    // Coach doc ID = E.164 phone number (e.g. "+13059155976")
    // Coaches can read/write their own document (create on first login)
    match /coaches/{phone} {
      allow read, write: if request.auth != null
        && request.auth.token.phone_number == phone;
    }

    // ── Players ──────────────────────────────────────────────────────────────
    // coachId field = coach phone number
    match /players/{playerId} {
      allow read: if request.auth != null
        && resource.data.coachId == request.auth.token.phone_number;
      allow write: if false; // Admin only
    }

    // ── Reports ──────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if request.auth != null
        && resource.data.coachId == request.auth.token.phone_number;
      allow create: if request.auth != null
        && request.resource.data.coachId == request.auth.token.phone_number;
      allow update: if request.auth != null
        && resource.data.coachId == request.auth.token.phone_number
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sentToParent']);
    }

    // ── Sessions ─────────────────────────────────────────────────────────────
    // Session doc ID = coach phone number
    match /sessions/{phone} {
      allow read, write: if request.auth != null
        && request.auth.token.phone_number == phone;
    }
  }
}
